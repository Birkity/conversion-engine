# App
APP_PORT=8000
PUBLIC_BASE_URL=

# Channels — Email (Resend SMTP relay; REST API is Cloudflare-blocked from ET)
# Free-tier rule: FROM must be onboarding@resend.dev; TO must be your Resend signup email.
RESEND_API_KEY=
RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=587
RESEND_FROM=onboarding@resend.dev
# OUTBOUND_SINK_EMAIL must be your Resend signup email (free-tier restriction)
OUTBOUND_SINK_EMAIL=
# Used by scripts/resend_smoketest.py — set to your Resend signup email
RESEND_SMOKE_TEST_EMAIL=
MAILERSEND_API_KEY=
# AT: use username=sandbox + sandbox key until live approval
AT_USERNAME=CONV-ENGINE
AT_API_KEY=
AT_SHORTCODE=
AT_SMOKE_TEST_PHONE=

# KILL-SWITCH — default false = route all outbound to OUTBOUND_SINK_EMAIL (safe)
LIVE_OUTBOUND_ENABLED=false

# CRM
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_PORTAL_ID=

# Calendar
CALCOM_BASE_URL=https://cal.com
CALCOM_EVENT_URL=
CALCOM_API_KEY=
CALCOM_WEBHOOK_SECRET=

# Webhook secrets (set after Render deploy — paste from each service's dashboard)
RESEND_WEBHOOK_SECRET=

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development

# LLMs
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
