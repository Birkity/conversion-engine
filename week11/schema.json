{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tenacious-Bench Task v0.1",
  "description": "A single evaluation task for the Tenacious-Bench benchmark. Each task is a (hiring_signal_brief, generated_email) pair with a machine-verifiable ground truth verdict.",
  "type": "object",
  "required": ["task_id", "source_mode", "difficulty", "input", "ground_truth", "metadata"],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^TB-[0-9]{3,4}$",
      "description": "Unique task identifier. Format: TB-001 through TB-9999."
    },
    "source_mode": {
      "type": "string",
      "enum": ["trace_derived", "programmatic", "synthesis", "adversarial"],
      "description": "How this task was generated."
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"],
      "description": "easy=single obvious dimension fail; medium=subtle D1/D2 fail; hard=only LLM judge catches it."
    },
    "input": {
      "type": "object",
      "required": ["hiring_signal_brief", "generated_email"],
      "additionalProperties": false,
      "properties": {
        "hiring_signal_brief": {
          "type": "object",
          "description": "The hiring signal brief as generated by agent/brief_generator.",
          "required": ["company", "hiring_velocity", "icp_segment", "confidence"],
          "properties": {
            "company": { "type": "string" },
            "hiring_velocity": {
              "type": "object",
              "required": ["direction", "delta_pct", "signal_strength"],
              "properties": {
                "direction": { "type": "string", "enum": ["accelerating", "decelerating", "stable"] },
                "delta_pct": { "type": "number" },
                "signal_strength": { "type": "string", "enum": ["strong", "moderate", "weak"] },
                "observation": { "type": "string" }
              }
            },
            "icp_segment": {
              "type": "string",
              "enum": ["Segment 1", "Segment 2", "Segment 3", "Segment 4", "ambiguous"]
            },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "ai_maturity_score": { "type": "integer", "minimum": 0, "maximum": 3 },
            "budget_urgency": { "type": "object" },
            "bench_match": { "type": "object" },
            "honesty_flags": { "type": "object" }
          }
        },
        "generated_email": {
          "type": "object",
          "required": ["subject", "body"],
          "additionalProperties": false,
          "properties": {
            "subject": { "type": "string" },
            "body": { "type": "string" },
            "grounding_facts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "icp_segment_used": { "type": "string" },
            "tone_warnings": {
              "type": "array",
              "items": { "type": "string" }
            },
            "word_count": { "type": "integer" }
          }
        }
      }
    },
    "ground_truth": {
      "type": "object",
      "required": ["verdict", "primary_failure_dimension", "dimension_scores"],
      "additionalProperties": false,
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["PASS", "REJECT"]
        },
        "primary_failure_dimension": {
          "type": "string",
          "enum": [
            "D1_icp_pitch_alignment",
            "D2_signal_directionality",
            "D3_grounding_completeness",
            "D4_tone_compliance",
            "D5_format_compliance",
            "none"
          ]
        },
        "dimension_scores": {
          "type": "object",
          "required": ["D2", "D3", "D4", "D5"],
          "properties": {
            "D1": { "type": ["integer", "null"], "enum": [0, 1, null] },
            "D2": { "type": "integer", "enum": [0, 1] },
            "D3": { "type": "integer", "enum": [0, 1] },
            "D4": { "type": "integer", "enum": [0, 1] },
            "D5": { "type": "integer", "enum": [0, 1] }
          }
        },
        "reject_reason": {
          "type": ["string", "null"],
          "description": "One-sentence explanation of why the primary dimension failed. null for PASS tasks."
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["company", "trace_id"],
      "properties": {
        "company": { "type": "string" },
        "trace_id": {
          "type": "string",
          "description": "Source trace identifier. Format: {slug}-{YYYY-MM-DD} for trace-derived, or 'programmatic-{id}' etc."
        },
        "velocity_delta_pct": { "type": "number" },
        "icp_segment": { "type": "string" },
        "ai_maturity_score": { "type": "integer" },
        "variant": {
          "type": "string",
          "enum": ["original", "corrupted_grounding", "counterfactual_segment", "counterfactual_velocity"],
          "description": "For trace-derived tasks, which variant of the original this is."
        }
      }
    }
  },
  "examples": [
    {
      "task_id": "TB-001",
      "source_mode": "trace_derived",
      "difficulty": "medium",
      "input": {
        "hiring_signal_brief": {
          "company": "SnapTrade",
          "hiring_velocity": {
            "direction": "decelerating",
            "delta_pct": -60.0,
            "signal_strength": "moderate",
            "observation": "Job postings have decreased in the last 60 days."
          },
          "icp_segment": "ambiguous",
          "confidence": 0.7,
          "ai_maturity_score": 0,
          "budget_urgency": { "level": "low", "signal": "Seed round $3.2M in 2021" },
          "bench_match": { "bench_available": true },
          "honesty_flags": { "weak_hiring_velocity_signal": false }
        },
        "generated_email": {
          "subject": "Context: Job postings decreased -60% in 60 days",
          "body": "SnapTrade Contact,\nJob postings have decreased 60% in the last 60 days.\nCompanies in your position often face bottlenecks integrating new APIs.\nTenacious provides engineers who can augment your team and accelerate API development.\nWhat are your biggest challenges in maintaining API integrations?\n\nBirkity\nResearch Partner, Tenacious Intelligence Corporation",
          "grounding_facts": ["Job postings have decreased 60% in the last 60 days.", "Seed round $3.2M in 2021"],
          "icp_segment_used": "Ambiguous",
          "tone_warnings": [],
          "word_count": 50
        }
      },
      "ground_truth": {
        "verdict": "REJECT",
        "primary_failure_dimension": "D2_signal_directionality",
        "dimension_scores": { "D1": null, "D2": 0, "D3": 1, "D4": 1, "D5": 1 },
        "reject_reason": "contraction signal (-60%) with growth-bottleneck pitch frame"
      },
      "metadata": {
        "company": "SnapTrade",
        "trace_id": "snaptrade-2026-04-28",
        "velocity_delta_pct": -60.0,
        "icp_segment": "ambiguous",
        "ai_maturity_score": 0,
        "variant": "original"
      }
    },
    {
      "task_id": "TB-002",
      "source_mode": "trace_derived",
      "difficulty": "easy",
      "input": {
        "hiring_signal_brief": {
          "company": "Arcana Analytics",
          "hiring_velocity": {
            "direction": "accelerating",
            "delta_pct": 100.0,
            "signal_strength": "strong",
            "observation": "Arcana Analytics has doubled its open job postings in the last 60 days."
          },
          "icp_segment": "Segment 1",
          "confidence": 0.9,
          "ai_maturity_score": 2,
          "budget_urgency": { "level": "high", "signal": "Series A $14M closed March 2026" },
          "bench_match": { "bench_available": true },
          "honesty_flags": { "weak_hiring_velocity_signal": false }
        },
        "generated_email": {
          "subject": "Context: Series A $14M closed March 2026",
          "body": "Jordan,\n\nArcana Analytics has doubled its open job postings in the last 60 days.\n\nCompanies scaling after a Series A often face bottlenecks integrating new ML engineers.\n\nTenacious provides pre-vetted, project-ready ML engineering pods that can deploy in days.\n\nWhat challenges are you encountering scaling your ML engineering team?\n\nBirkity\nResearch Partner, Tenacious Intelligence Corporation",
          "grounding_facts": ["Arcana Analytics has doubled its open job postings in the last 60 days", "Series A $14M closed March 2026"],
          "icp_segment_used": "Segment 1",
          "tone_warnings": [],
          "word_count": 56
        }
      },
      "ground_truth": {
        "verdict": "PASS",
        "primary_failure_dimension": "none",
        "dimension_scores": { "D1": 1, "D2": 1, "D3": 1, "D4": 1, "D5": 1 },
        "reject_reason": null
      },
      "metadata": {
        "company": "Arcana Analytics",
        "trace_id": "arcana-2026-04-27",
        "velocity_delta_pct": 100.0,
        "icp_segment": "Segment 1",
        "ai_maturity_score": 2,
        "variant": "original"
      }
    },
    {
      "task_id": "TB-003",
      "source_mode": "trace_derived",
      "difficulty": "hard",
      "input": {
        "hiring_signal_brief": {
          "company": "WiseiTech",
          "hiring_velocity": {
            "direction": "decelerating",
            "delta_pct": -100.0,
            "signal_strength": "weak",
            "observation": "WiseiTech's hiring appears to be decelerating based on a decrease in job postings."
          },
          "icp_segment": "ambiguous",
          "confidence": 0.6,
          "ai_maturity_score": 0,
          "budget_urgency": { "level": "unknown", "signal": null },
          "bench_match": { "bench_available": true },
          "honesty_flags": { "weak_hiring_velocity_signal": true }
        },
        "generated_email": {
          "subject": "Context: decelerating job postings",
          "body": "WiseiTech Contact,\n\nI see WiseiTech's job postings have decreased recently.\n\nCompanies in your position often find themselves needing to augment existing Python, Big Data, and ML capabilities.\n\nTenacious provides research-backed engineers available on-demand.\n\nHow are you handling the current workload with the reduced hiring?\n\nBirkity\nResearch Partner, Tenacious Intelligence Corporation",
          "grounding_facts": ["WiseiTech's hiring appears to be decelerating based on a decrease in job postings."],
          "icp_segment_used": "Ambiguous",
          "tone_warnings": [],
          "word_count": 51
        }
      },
      "ground_truth": {
        "verdict": "REJECT",
        "primary_failure_dimension": "D1_icp_pitch_alignment",
        "dimension_scores": { "D1": 0, "D2": 0, "D3": 1, "D4": 1, "D5": 1 },
        "reject_reason": "segment=Ambiguous but email makes a product claim (augmentation pitch); D2 also fails: -100% velocity with augmentation frame"
      },
      "metadata": {
        "company": "WiseiTech",
        "trace_id": "wiseitech-2026-04-27",
        "velocity_delta_pct": -100.0,
        "icp_segment": "ambiguous",
        "ai_maturity_score": 0,
        "variant": "original"
      }
    }
  ]
}
